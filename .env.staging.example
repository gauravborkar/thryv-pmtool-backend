# =============================================================
# Thryv PM Tool — Backend | STAGING Environment
# =============================================================
# These variables must be set as secrets in your CI/CD platform
# (GitHub Actions → Settings → Secrets and variables → Actions)
# or in your staging host's environment config.
# NEVER store real values in this file.
# =============================================================

# ----- Database -----
DATABASE_URL="postgresql://<user>:<password>@<staging-db-host>:5432/agency_pm_staging"

# ----- Auth -----
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="<generate-a-secure-random-string>"

# ----- Server -----
PORT=3001
