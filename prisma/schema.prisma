generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== LOOKUP TABLES ====================

model UserRole {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())

  users       User[]
  invitations Invitation[]

  @@map("user_roles")
}

model Invitation {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  token      String   @unique
  role_id    Int
  role       UserRole @relation(fields: [role_id], references: [id])
  expires_at DateTime
  is_used    Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([token])
  @@index([email])
  @@map("invitations")
}

model TaskStatus {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())

  tasks Task[]

  @@map("task_statuses")
}

model ContentType {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())

  line_items         ContentPackageLineItem[]
  version_line_items ContentPackageVersionLineItem[]

  @@map("content_types")
}

model BillingCycle {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())

  line_items         ContentPackageLineItem[]
  version_line_items ContentPackageVersionLineItem[]

  @@map("billing_cycles")
}

model SocialPlatform {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())

  line_items         ContentPackageLineItem[]
  version_line_items ContentPackageVersionLineItem[]

  @@map("social_platforms")
}

// ==================== MAIN TABLES ====================

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password   String
  name       String
  role_id    Int
  is_active              Boolean   @default(true)
  reset_password_token   String?   @unique
  reset_password_expires DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  // Relations
  role            UserRole @relation(fields: [role_id], references: [id])
  managed_clients Client[] @relation("ClientManager")
  assigned_tasks  Task[]   @relation("TaskDesigner")
  created_tasks   Task[]   @relation("TaskCreator")
  comments        Comment[]
  uploads         Attachment[]
  audit_logs         AuditLog[]
  content_packages         ContentPackage[]
  content_package_versions ContentPackageVersion[] @relation("PackageVersionEditor")


  // Indexes
  @@index([role_id])
  @@index([email])
  @@index([is_active])
  @@map("users")
}

model Client {
  id            Int      @id @default(autoincrement())
  name          String
  brand_details Json?
  active_month  DateTime
  manager_id    Int
  is_active     Boolean  @default(true)
  timezone      String   @default("UTC")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  manager          User            @relation("ClientManager", fields: [manager_id], references: [id])
  packages         Package[]
  calendar_entries CalendarEntry[]
  uploads          Attachment[]

  // Indexes
  @@index([manager_id])
  @@index([active_month])
  @@index([is_active])
  @@map("clients")
}

model Package {
  id          Int      @id @default(autoincrement())
  client_id   Int
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  month       DateTime
  created_at  DateTime @default(now())

  // Relations
  client Client @relation(fields: [client_id], references: [id])

  // Indexes
  @@index([client_id])
  @@index([month])
  @@map("packages")
}

model ContentPackage {
  id              String   @id @default(uuid())
  name            String
  description     String?
  created_by_id   Int
  current_version Int      @default(1)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  created_by User                     @relation(fields: [created_by_id], references: [id])
  line_items ContentPackageLineItem[]
  scheduledPosts ScheduledPost[]
  versions   ContentPackageVersion[]
  distributionRule DistributionRule?

  @@index([created_by_id])
  @@index([created_at])
  @@map("content_packages")
}

model ContentPackageLineItem {
  id                                String   @id @default(uuid())
  package_id                        String
  content_type_id                   Int
  platform_id                       Int
  billing_cycle_id                  Int
  quantity                          Int      @default(1)
  notes                             String?
  eligible_for_partial_regeneration Boolean  @default(false)
  created_at                        DateTime @default(now())

  package       ContentPackage @relation(fields: [package_id], references: [id], onDelete: Cascade)
  content_type  ContentType    @relation(fields: [content_type_id], references: [id])
  platform      SocialPlatform @relation(fields: [platform_id], references: [id])
  billing_cycle BillingCycle   @relation(fields: [billing_cycle_id], references: [id])

  @@index([package_id])
  @@index([content_type_id])
  @@index([platform_id])
  @@index([billing_cycle_id])
  @@map("content_package_line_items")
}

model ContentPackageVersion {
  id              String   @id @default(uuid())
  package_id      String
  version_number  Int
  name            String
  description     String?
  change_type     String
  change_summary  Json?
  edited_by_id    Int
  created_at      DateTime @default(now())

  package    ContentPackage                  @relation(fields: [package_id], references: [id], onDelete: Cascade)
  edited_by  User                            @relation("PackageVersionEditor", fields: [edited_by_id], references: [id])
  line_items ContentPackageVersionLineItem[]

  @@unique([package_id, version_number])
  @@index([package_id])
  @@index([created_at])
  @@map("content_package_versions")
}

model ContentPackageVersionLineItem {
  id                                String  @id @default(uuid())
  version_id                        String
  source_line_item_id               String?
  content_type_id                   Int
  platform_id                       Int
  billing_cycle_id                  Int
  quantity                          Int
  notes                             String?
  change_kind                       String
  eligible_for_partial_regeneration Boolean @default(false)

  version       ContentPackageVersion @relation(fields: [version_id], references: [id], onDelete: Cascade)
  content_type  ContentType           @relation(fields: [content_type_id], references: [id])
  platform      SocialPlatform        @relation(fields: [platform_id], references: [id])
  billing_cycle BillingCycle          @relation(fields: [billing_cycle_id], references: [id])

  @@index([version_id])
  @@map("content_package_version_line_items")
}

model CalendarEntry {
  id          Int      @id @default(autoincrement())
  client_id   Int
  date        DateTime
  title       String
  description String?
  created_at  DateTime @default(now())

  // Relations
  client Client @relation(fields: [client_id], references: [id])
  task   Task?

  // Indexes
  @@index([client_id])
  @@index([date])
  @@map("calendar_entries")
}

model Task {
  id                    Int      @id @default(autoincrement())
  calendar_entry_id     Int?     @unique
  title                 String
  status_id             Int
  priority              Int      @default(2)
  designer_due_date     DateTime
  publish_date          DateTime
  assigned_designer_id  Int?
  created_by_manager_id Int
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  // Relations
  calendar_entry     CalendarEntry? @relation(fields: [calendar_entry_id], references: [id])
  status             TaskStatus     @relation(fields: [status_id], references: [id])
  assigned_designer  User?          @relation("TaskDesigner", fields: [assigned_designer_id], references: [id])
  created_by_manager User           @relation("TaskCreator", fields: [created_by_manager_id], references: [id])
  comments           Comment[]
  uploads            Attachment[]

  // Indexes
  @@index([assigned_designer_id])
  @@index([status_id])
  @@index([publish_date])
  @@index([priority])
  @@map("tasks")
}

model Comment {
  id         Int      @id @default(autoincrement())
  content    String
  task_id    Int
  author_id  Int
  created_at DateTime @default(now())

  // Relations
  task   Task @relation(fields: [task_id], references: [id], onDelete: Cascade)
  author User @relation(fields: [author_id], references: [id])

  // Indexes
  @@index([task_id])
  @@index([author_id])
  @@map("comments")
}

model Attachment {
  id          Int      @id @default(autoincrement())
  file_name   String
  file_url    String
  file_type   String
  file_size   Int
  task_id     Int?
  client_id   Int?
  uploaded_by Int
  created_at  DateTime @default(now())

  // Relations
  task  Task?   @relation(fields: [task_id], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [client_id], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [uploaded_by], references: [id])

  // Indexes
  @@index([task_id])
  @@index([client_id])
  @@index([uploaded_by])
  @@map("attachments")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  action     String
  entity     String?
  entity_id  Int?
  details    Json?
  ip_address String?
  created_at DateTime @default(now())

  // Relations
  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([action])
  @@index([created_at])
  @@map("audit_logs")
}

// ==================== DISTRIBUTION RULES ====================

model DistributionRule {
  id                       Int      @id @default(autoincrement())
  package_id               String   @unique
  formatSequence           Json     // array of format identifiers
  peakDays                 Json     // array of ISO weekday numbers (1-7)
  maxConsecutiveSameFormat Int      @default(1)
  regenerationMode         String   @default("ALL")
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  // Relations
  package        ContentPackage @relation(fields: [package_id], references: [id], onDelete: Cascade)
  scheduledPosts ScheduledPost[]
}

model ScheduledPost {
  id            Int      @id @default(autoincrement())
  package_id    String
  scheduled_at  DateTime
  format        String
  is_locked     Boolean  @default(false)
  created_at    DateTime @default(now())

  package ContentPackage @relation(fields: [package_id], references: [id])
  rule    DistributionRule? @relation(fields: [ruleId], references: [id])
  ruleId  Int?

  @@index([package_id])
  @@index([scheduled_at])
  @@index([is_locked])
}

model BlackoutDate {
  id          Int      @id @default(autoincrement())
  date        DateTime @unique
  reason      String?
  created_at  DateTime @default(now())
  
  @@index([date])
  @@map("blackout_dates")
}