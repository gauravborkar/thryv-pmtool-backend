generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== LOOKUP TABLES ====================

model UserRole {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  created_at  DateTime @default(now())

  users       User[]
  invitations Invitation[]
  permissions Permission[]
  tasks_assigned     Task[]         @relation("TaskAssignedRoles")

  @@map("user_roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique // e.g. "task:create", "task:assign"
  description String?
  created_at  DateTime @default(now())

  roles UserRole[]

  @@map("permissions")
}

model Invitation {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  token      String   @unique
  role_id    Int
  role       UserRole @relation(fields: [role_id], references: [id])
  expires_at DateTime
  is_used    Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([token])
  @@index([email])
  @@index([role_id])
  @@map("invitations")
}

model TaskStatus {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())

  tasks Task[]

  @@map("task_statuses")
}

model TaskType {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())

  tasks      Task[]
  tasks_many Task[] @relation("TaskToTaskTypes")

  @@map("task_types")
}

model ContentType {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())

  line_items         ContentPackageLineItem[]
  version_line_items ContentPackageVersionLineItem[]

  @@map("content_types")
}

model BillingCycle {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())

  line_items         ContentPackageLineItem[]
  version_line_items ContentPackageVersionLineItem[]

  @@map("billing_cycles")
}

model SocialPlatform {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())

  line_items         ContentPackageLineItem[]
  version_line_items ContentPackageVersionLineItem[]

  @@map("social_platforms")
}

// ==================== MAIN TABLES ====================

model User {
  id                     Int       @id @default(autoincrement())
  email                  String    @unique
  password               String
  name                   String
  is_active              Boolean   @default(true)
  reset_password_token   String?   @unique
  reset_password_expires DateTime?
  current_session_token  String?
  custom_permissions     Json?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  // Relations
  roles                    UserRole[]
  managed_clients          Client[]                @relation("ClientManager")
  assigned_tasks           Task[]                  @relation("TaskDesigner")
  created_tasks            Task[]                  @relation("TaskCreator")
  mentioned_tasks          Task[]                  @relation("TaskMentions")
  comments                 Comment[]
  uploads                  Attachment[]
  audit_logs               AuditLog[]
  content_packages         ContentPackage[]
  content_package_versions ContentPackageVersion[] @relation("PackageVersionEditor")
  notifications            Notification[]
  created_channels         ChatChannel[]           @relation("ChannelCreator")
  chat_memberships         ChatChannelMember[]
  chat_messages            ChatMessage[]
  assigned_addons          AddOn[]                 @relation("AddOnAssignee")
  created_addons           AddOn[]                 @relation("AddOnCreator")
  created_subscriptions    Subscription[]          @relation("SubscriptionCreator")

  // Indexes
  @@index([email])
  @@index([is_active])
  @@map("users")
}

model Client {
  id                Int      @id @default(autoincrement())
  name              String
  brand_details     Json?
  active_month      DateTime
  manager_id        Int
  is_active         Boolean  @default(true)
  timezone          String   @default("UTC")
  google_drive_link String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  // Relations
  manager          User              @relation("ClientManager", fields: [manager_id], references: [id])
  packages         Package[]
  content_packages ContentPackage[]
  calendar_entries CalendarEntry[]
  uploads          Attachment[]
  knowledge        ClientKnowledge[]
  chat_channels    ChatChannel[]
  addons           AddOn[]
  subscriptions    Subscription[]

  // Indexes
  @@index([manager_id])
  @@index([active_month])
  @@index([is_active])
  @@map("clients")
}

model Package {
  id          Int      @id @default(autoincrement())
  client_id   Int
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  month       DateTime
  created_at  DateTime @default(now())

  // Relations
  client Client @relation(fields: [client_id], references: [id])

  // Indexes
  @@index([client_id])
  @@index([month])
  @@map("packages")
}

model ContentPackage {
  id              String   @id @default(uuid())
  client_id       Int?
  name            String
  description     String?
  created_by_id   Int
  current_version Int      @default(1)
  is_deleted      Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  client           Client?                  @relation(fields: [client_id], references: [id])
  created_by       User                     @relation(fields: [created_by_id], references: [id])
  line_items       ContentPackageLineItem[]
  scheduledPosts   ScheduledPost[]
  versions         ContentPackageVersion[]
  distributionRule DistributionRule?

  @@index([created_by_id])
  @@index([client_id])
  @@index([created_at])
  @@map("content_packages")
}

model ContentPackageLineItem {
  id                                String   @id @default(uuid())
  package_id                        String
  content_type_id                   Int
  platform_id                       Int
  billing_cycle_id                  Int
  quantity                          Int      @default(1)
  notes                             String?
  eligible_for_partial_regeneration Boolean  @default(false)
  created_at                        DateTime @default(now())

  package       ContentPackage @relation(fields: [package_id], references: [id], onDelete: Cascade)
  content_type  ContentType    @relation(fields: [content_type_id], references: [id])
  platform      SocialPlatform @relation(fields: [platform_id], references: [id])
  billing_cycle BillingCycle   @relation(fields: [billing_cycle_id], references: [id])

  @@index([package_id])
  @@index([content_type_id])
  @@index([platform_id])
  @@index([billing_cycle_id])
  @@map("content_package_line_items")
}

model ContentPackageVersion {
  id             String   @id @default(uuid())
  package_id     String
  version_number Int
  name           String
  description    String?
  change_type    String
  change_summary Json?
  edited_by_id   Int
  created_at     DateTime @default(now())

  package    ContentPackage                  @relation(fields: [package_id], references: [id], onDelete: Cascade)
  edited_by  User                            @relation("PackageVersionEditor", fields: [edited_by_id], references: [id])
  line_items ContentPackageVersionLineItem[]

  @@unique([package_id, version_number])
  @@index([package_id])
  @@index([created_at])
  @@map("content_package_versions")
}

model ContentPackageVersionLineItem {
  id                                String  @id @default(uuid())
  version_id                        String
  source_line_item_id               String?
  content_type_id                   Int
  platform_id                       Int
  billing_cycle_id                  Int
  quantity                          Int
  notes                             String?
  change_kind                       String
  eligible_for_partial_regeneration Boolean @default(false)

  version       ContentPackageVersion @relation(fields: [version_id], references: [id], onDelete: Cascade)
  content_type  ContentType           @relation(fields: [content_type_id], references: [id])
  platform      SocialPlatform        @relation(fields: [platform_id], references: [id])
  billing_cycle BillingCycle          @relation(fields: [billing_cycle_id], references: [id])

  @@index([version_id])
  @@map("content_package_version_line_items")
}

model CalendarEntry {
  id              Int      @id @default(autoincrement())
  client_id       Int
  date            DateTime
  title           String
  description     String?
  transcript      String?
  hashtags        String?
  reference_links String?
  is_holiday      Boolean  @default(false)
  created_at      DateTime @default(now())

  // Relations
  client Client @relation(fields: [client_id], references: [id])
  task   Task?

  // Indexes
  @@index([client_id])
  @@index([date])
  @@map("calendar_entries")
}

model ClientKnowledge {
  id         Int      @id @default(autoincrement())
  client_id  Int
  sheet_name String
  data       Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  client Client @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@index([client_id])
  @@map("client_knowledge")
}

model Task {
  id                    Int       @id @default(autoincrement())
  calendar_entry_id     Int?      @unique
  title                 String
  status_id             Int
  task_type_id          Int?
  priority              Int       @default(2)
  start_date            DateTime?
  designer_due_date     DateTime
  publish_date          DateTime
  assigned_designer_id  Int?
  created_by_manager_id Int
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  is_deleted            Boolean   @default(false)
  drive_link            String?

  // Relations
  calendar_entry     CalendarEntry? @relation(fields: [calendar_entry_id], references: [id])
  status             TaskStatus     @relation(fields: [status_id], references: [id])
  task_type          TaskType?      @relation(fields: [task_type_id], references: [id])
  task_types         TaskType[]     @relation("TaskToTaskTypes")
  assigned_designer  User?          @relation("TaskDesigner", fields: [assigned_designer_id], references: [id])
  created_by_manager User           @relation("TaskCreator", fields: [created_by_manager_id], references: [id])
  mentioned_users    User[]         @relation("TaskMentions")
  assigned_roles     UserRole[]     @relation("TaskAssignedRoles")
  comments           Comment[]
  uploads            Attachment[]

  // Indexes
  @@index([assigned_designer_id])
  @@index([status_id])
  @@index([task_type_id])
  @@index([publish_date])
  @@index([priority])
  @@index([created_by_manager_id])
  @@index([is_deleted])
  @@map("tasks")
}

model Comment {
  id         Int      @id @default(autoincrement())
  content    String
  task_id    Int
  author_id  Int
  created_at DateTime @default(now())

  // Relations
  task   Task @relation(fields: [task_id], references: [id], onDelete: Cascade)
  author User @relation(fields: [author_id], references: [id])

  // Indexes
  @@index([task_id])
  @@index([author_id])
  @@map("comments")
}

model Attachment {
  id          Int      @id @default(autoincrement())
  file_name   String
  file_url    String
  file_type   String
  file_size   Int
  task_id     Int?
  client_id   Int?
  uploaded_by Int
  created_at  DateTime @default(now())

  // Relations
  task   Task?   @relation(fields: [task_id], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [client_id], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [uploaded_by], references: [id])

  // Indexes
  @@index([task_id])
  @@index([client_id])
  @@index([uploaded_by])
  @@map("attachments")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  action     String
  entity     String?
  entity_id  Int?
  details    Json?
  ip_address String?
  created_at DateTime @default(now())

  // Relations
  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([action])
  @@index([created_at])
  @@map("audit_logs")
}

// ==================== DISTRIBUTION RULES ====================

model DistributionRule {
  id                       Int      @id @default(autoincrement())
  package_id               String   @unique
  formatSequence           Json // array of format identifiers
  peakDays                 Json // array of ISO weekday numbers (1-7)
  maxConsecutiveSameFormat Int      @default(1)
  regenerationMode         String   @default("ALL")
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  // Relations
  package        ContentPackage  @relation(fields: [package_id], references: [id], onDelete: Cascade)
  scheduledPosts ScheduledPost[]
}

model ScheduledPost {
  id           Int      @id @default(autoincrement())
  package_id   String
  scheduled_at DateTime
  format       String
  is_locked    Boolean  @default(false)
  created_at   DateTime @default(now())

  package ContentPackage    @relation(fields: [package_id], references: [id])
  rule    DistributionRule? @relation(fields: [ruleId], references: [id])
  ruleId  Int?

  @@index([package_id])
  @@index([scheduled_at])
  @@index([is_locked])
}

model BlackoutDate {
  id         Int      @id @default(autoincrement())
  date       DateTime @unique
  reason     String?
  created_at DateTime @default(now())

  @@index([date])
  @@map("blackout_dates")
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id             Int      @id @default(autoincrement())
  user_id        Int
  title          String
  message        String
  type           String
  is_read        Boolean  @default(false)
  reference_id   Int?
  reference_type String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([is_read])
  @@map("notifications")
}

// ==================== SYSTEM SETTINGS ====================

model RetentionPolicy {
  id         Int      @id @default(autoincrement())
  isEnabled  Boolean  @default(false)
  keepDays   Int      @default(30)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("retention_policies")
}

model AccessControlRule {
  id         Int      @id @default(autoincrement())
  section    String   @unique
  roles      Json     // e.g. ["ADMIN", "MANAGER"]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("access_control_rules")
}

// ==================== CHAT ====================

model ChatChannel {
  id            Int      @id @default(autoincrement())
  name          String? // Optional for direct messages
  type          String // 'GROUP' | 'DIRECT' | 'CLIENT'
  client_id     Int?
  created_by_id Int
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  is_deleted    Boolean  @default(false)

  client     Client?             @relation(fields: [client_id], references: [id], onDelete: Cascade)
  created_by User                @relation("ChannelCreator", fields: [created_by_id], references: [id])
  members    ChatChannelMember[]
  messages   ChatMessage[]

  @@index([client_id])
  @@index([created_by_id])
  @@map("chat_channels")
}

model ChatChannelMember {
  id           Int      @id @default(autoincrement())
  channel_id   Int
  user_id      Int
  joined_at    DateTime @default(now())
  last_read_at DateTime @default(now())

  channel ChatChannel @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([channel_id, user_id])
  @@index([channel_id])
  @@index([user_id])
  @@map("chat_channel_members")
}

model ChatMessage {
  id         Int      @id @default(autoincrement())
  channel_id Int
  sender_id  Int
  content    String
  type       String   @default("TEXT") // 'TEXT' | 'FILE' | 'TASK_LINK'
  metadata   Json? // Stores attachment URL or linked task ID
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  channel ChatChannel @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  sender  User        @relation(fields: [sender_id], references: [id])

  @@index([channel_id])
  @@index([sender_id])
  @@map("chat_messages")
}

model AddOn {
  id             Int      @id @default(autoincrement())
  client_id      Int
  title          String
  description    String?
  date           DateTime
  price          Decimal  @db.Decimal(10, 2)
  assigned_to_id Int?
  created_by_id  Int
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  is_deleted     Boolean  @default(false)

  // Relations
  client      Client @relation(fields: [client_id], references: [id], onDelete: Cascade)
  assigned_to User?  @relation("AddOnAssignee", fields: [assigned_to_id], references: [id])
  created_by  User   @relation("AddOnCreator", fields: [created_by_id], references: [id])

  // Indexes
  @@index([client_id])
  @@index([assigned_to_id])
  @@index([created_by_id])
  @@map("addons")
}

model Subscription {
  id             Int      @id @default(autoincrement())
  client_id      Int?
  title          String
  description    String?
  price          Decimal  @db.Decimal(10, 2)
  payment_method String
  due_date       DateTime
  created_by_id  Int
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  is_deleted     Boolean  @default(false)

  // Relations
  client     Client? @relation(fields: [client_id], references: [id], onDelete: Cascade)
  created_by User    @relation("SubscriptionCreator", fields: [created_by_id], references: [id])

  // Indexes
  @@index([client_id])
  @@index([created_by_id])
  @@map("subscriptions")
}
