generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserRole {
  id             Int              @id @default(autoincrement())
  name           String           @unique
  created_at     DateTime         @default(now())
  description    String?
  UserToUserRole UserToUserRole[]
  invitations    Invitation[]
  permissions    Permission[]     @relation("PermissionToUserRole")
  tasks_assigned Task[]           @relation("TaskAssignedRoles")

  @@map("user_roles")
}

model Permission {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String?
  created_at  DateTime   @default(now())
  roles       UserRole[] @relation("PermissionToUserRole")

  @@map("permissions")
}

model Invitation {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  token      String   @unique
  role_id    Int
  expires_at DateTime
  is_used    Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  role       UserRole @relation(fields: [role_id], references: [id])

  @@index([token])
  @@index([email])
  @@index([role_id])
  @@map("invitations")
}

model TaskStatus {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())
  tasks      Task[]

  @@map("task_statuses")
}

model TaskType {
  id              Int               @id @default(autoincrement())
  name            String            @unique
  created_at      DateTime          @default(now())
  TaskToTaskTypes TaskToTaskTypes[]
  tasks           Task[]

  @@map("task_types")
}

model ContentType {
  id                 Int                             @id @default(autoincrement())
  name               String                          @unique
  created_at         DateTime                        @default(now())
  line_items         ContentPackageLineItem[]
  version_line_items ContentPackageVersionLineItem[]

  @@map("content_types")
}

model BillingCycle {
  id                 Int                             @id @default(autoincrement())
  name               String                          @unique
  created_at         DateTime                        @default(now())
  line_items         ContentPackageLineItem[]
  version_line_items ContentPackageVersionLineItem[]

  @@map("billing_cycles")
}

model SocialPlatform {
  id                 Int                             @id @default(autoincrement())
  name               String                          @unique
  created_at         DateTime                        @default(now())
  line_items         ContentPackageLineItem[]
  version_line_items ContentPackageVersionLineItem[]
  task_specs         TaskPlatformSpec[]

  @@map("social_platforms")
}

model User {
  id                       Int                     @id @default(autoincrement())
  email                    String                  @unique
  password                 String
  name                     String
  is_active                Boolean                 @default(true)
  created_at               DateTime                @default(now())
  updated_at               DateTime                @updatedAt
  reset_password_expires   DateTime?
  reset_password_token     String?                 @unique
  current_session_token    String?
  custom_permissions       Json?
  UserToUserRole           UserToUserRole[]
  assigned_addons          AddOn[]                 @relation("AddOnAssignee")
  created_addons           AddOn[]                 @relation("AddOnCreator")
  uploads                  Attachment[]
  audit_logs               AuditLog[]
  chat_memberships         ChatChannelMember[]
  created_channels         ChatChannel[]           @relation("ChannelCreator")
  chat_messages            ChatMessage[]
  managed_clients          Client[]                @relation("ClientManager")
  comments                 Comment[]
  content_package_versions ContentPackageVersion[] @relation("PackageVersionEditor")
  content_packages         ContentPackage[]
  notifications            Notification[]
  created_subscriptions    Subscription[]          @relation("SubscriptionCreator")
  assigned_tasks           Task[]                  @relation("TaskDesigner")
  created_tasks            Task[]                  @relation("TaskCreator")
  mentioned_tasks          Task[]                  @relation("TaskMentions")

  @@index([email])
  @@index([is_active])
  @@map("users")
}

model Client {
  id                Int               @id @default(autoincrement())
  name              String
  brand_details     Json?
  active_month      DateTime
  manager_id        Int
  is_active         Boolean           @default(true)
  timezone          String            @default("UTC")
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  google_drive_link String?
  is_onboard        Boolean           @default(true)
  addons            AddOn[]
  uploads           Attachment[]
  calendar_entries  CalendarEntry[]
  chat_channels     ChatChannel[]
  knowledge         ClientKnowledge[]
  manager           User              @relation("ClientManager", fields: [manager_id], references: [id])
  content_packages  ContentPackage[]
  packages          Package[]
  subscriptions     Subscription[]

  @@index([manager_id])
  @@index([active_month])
  @@index([is_active])
  @@index([is_onboard])
  @@map("clients")
}

model Package {
  id          Int      @id @default(autoincrement())
  client_id   Int
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  month       DateTime
  created_at  DateTime @default(now())
  client      Client   @relation(fields: [client_id], references: [id])

  @@index([client_id])
  @@index([month])
  @@map("packages")
}

model ContentPackage {
  id               String                   @id @default(uuid())
  name             String
  description      String?
  created_by_id    Int
  created_at       DateTime                 @default(now())
  updated_at       DateTime                 @updatedAt
  current_version  Int                      @default(1)
  client_id        Int?
  is_deleted       Boolean                  @default(false)
  price            Decimal?                 @db.Decimal(10, 2)
  distributionRule DistributionRule?
  scheduledPosts   ScheduledPost[]
  line_items       ContentPackageLineItem[]
  versions         ContentPackageVersion[]
  client           Client?                  @relation(fields: [client_id], references: [id])
  created_by       User                     @relation(fields: [created_by_id], references: [id])

  @@index([created_by_id])
  @@index([client_id])
  @@index([created_at])
  @@map("content_packages")
}

model ContentPackageLineItem {
  id                                String         @id @default(uuid())
  package_id                        String
  content_type_id                   Int
  platform_id                       Int
  billing_cycle_id                  Int
  quantity                          Int            @default(1)
  notes                             String?
  created_at                        DateTime       @default(now())
  eligible_for_partial_regeneration Boolean        @default(false)
  billing_cycle                     BillingCycle   @relation(fields: [billing_cycle_id], references: [id])
  content_type                      ContentType    @relation(fields: [content_type_id], references: [id])
  package                           ContentPackage @relation(fields: [package_id], references: [id], onDelete: Cascade)
  platform                          SocialPlatform @relation(fields: [platform_id], references: [id])

  @@index([package_id])
  @@index([content_type_id])
  @@index([platform_id])
  @@index([billing_cycle_id])
  @@map("content_package_line_items")
}

model ContentPackageVersion {
  id             String                          @id @default(uuid())
  package_id     String
  version_number Int
  name           String
  description    String?
  change_type    String
  change_summary Json?
  edited_by_id   Int
  created_at     DateTime                        @default(now())
  line_items     ContentPackageVersionLineItem[]
  edited_by      User                            @relation("PackageVersionEditor", fields: [edited_by_id], references: [id])
  package        ContentPackage                  @relation(fields: [package_id], references: [id], onDelete: Cascade)

  @@unique([package_id, version_number])
  @@index([package_id])
  @@index([created_at])
  @@map("content_package_versions")
}

model ContentPackageVersionLineItem {
  id                                String                @id @default(uuid())
  version_id                        String
  source_line_item_id               String?
  content_type_id                   Int
  platform_id                       Int
  billing_cycle_id                  Int
  quantity                          Int
  notes                             String?
  change_kind                       String
  eligible_for_partial_regeneration Boolean               @default(false)
  billing_cycle                     BillingCycle          @relation(fields: [billing_cycle_id], references: [id])
  content_type                      ContentType           @relation(fields: [content_type_id], references: [id])
  platform                          SocialPlatform        @relation(fields: [platform_id], references: [id])
  version                           ContentPackageVersion @relation(fields: [version_id], references: [id], onDelete: Cascade)

  @@index([version_id])
  @@map("content_package_version_line_items")
}

model CalendarEntry {
  id              Int      @id @default(autoincrement())
  client_id       Int
  date            DateTime
  title           String
  description     String?
  created_at      DateTime @default(now())
  hashtags        String?
  is_holiday      Boolean  @default(false)
  reference_links String?
  transcript      String?
  client          Client   @relation(fields: [client_id], references: [id])
  task            Task?

  @@index([client_id])
  @@index([date])
  @@map("calendar_entries")
}

model ClientKnowledge {
  id         Int      @id @default(autoincrement())
  client_id  Int
  sheet_name String
  data       Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  client     Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@index([client_id])
  @@map("client_knowledge")
}

model Task {
  id                    Int                @id @default(autoincrement())
  calendar_entry_id     Int?               @unique
  title                 String
  status_id             Int
  priority              Int                @default(2)
  designer_due_date     DateTime
  publish_date          DateTime
  assigned_designer_id  Int?
  created_by_manager_id Int
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt
  start_date            DateTime?
  task_type_id          Int?
  is_deleted            Boolean            @default(false)
  drive_link            String?
  TaskToTaskTypes       TaskToTaskTypes[]
  uploads               Attachment[]
  comments              Comment[]
  platform_specs        TaskPlatformSpec[]
  assigned_designer     User?              @relation("TaskDesigner", fields: [assigned_designer_id], references: [id])
  calendar_entry        CalendarEntry?     @relation(fields: [calendar_entry_id], references: [id])
  created_by_manager    User               @relation("TaskCreator", fields: [created_by_manager_id], references: [id])
  status                TaskStatus         @relation(fields: [status_id], references: [id])
  task_type             TaskType?          @relation(fields: [task_type_id], references: [id])
  assigned_roles        UserRole[]         @relation("TaskAssignedRoles")
  mentioned_users       User[]             @relation("TaskMentions")

  @@index([assigned_designer_id])
  @@index([status_id])
  @@index([task_type_id])
  @@index([publish_date])
  @@index([priority])
  @@index([created_by_manager_id])
  @@index([is_deleted])
  @@map("tasks")
}

model TaskPlatformSpec {
  id          Int            @id @default(autoincrement())
  task_id     Int
  platform_id Int
  post_specs  String?
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  platform    SocialPlatform @relation(fields: [platform_id], references: [id], onDelete: Cascade)
  task        Task           @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@unique([task_id, platform_id])
  @@index([task_id])
  @@index([platform_id])
  @@map("task_platform_specs")
}

model Comment {
  id         Int      @id @default(autoincrement())
  content    String
  task_id    Int
  author_id  Int
  created_at DateTime @default(now())
  author     User     @relation(fields: [author_id], references: [id])
  task       Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([task_id])
  @@index([author_id])
  @@map("comments")
}

model Attachment {
  id          Int      @id @default(autoincrement())
  file_name   String
  file_url    String
  file_type   String
  file_size   Int
  task_id     Int?
  client_id   Int?
  uploaded_by Int
  created_at  DateTime @default(now())
  client      Client?  @relation(fields: [client_id], references: [id], onDelete: Cascade)
  task        Task?    @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [uploaded_by], references: [id])

  @@index([task_id])
  @@index([client_id])
  @@index([uploaded_by])
  @@map("attachments")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  action     String
  entity     String?
  entity_id  Int?
  details    Json?
  ip_address String?
  created_at DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([action])
  @@index([created_at])
  @@map("audit_logs")
}

model DistributionRule {
  id                       Int             @id @default(autoincrement())
  package_id               String          @unique
  formatSequence           Json
  peakDays                 Json
  maxConsecutiveSameFormat Int             @default(1)
  regenerationMode         String          @default("ALL")
  created_at               DateTime        @default(now())
  updated_at               DateTime        @updatedAt
  package                  ContentPackage  @relation(fields: [package_id], references: [id], onDelete: Cascade)
  scheduledPosts           ScheduledPost[]
}

model ScheduledPost {
  id           Int               @id @default(autoincrement())
  package_id   String
  scheduled_at DateTime
  format       String
  is_locked    Boolean           @default(false)
  created_at   DateTime          @default(now())
  ruleId       Int?
  package      ContentPackage    @relation(fields: [package_id], references: [id])
  rule         DistributionRule? @relation(fields: [ruleId], references: [id])

  @@index([package_id])
  @@index([scheduled_at])
  @@index([is_locked])
}

model BlackoutDate {
  id         Int      @id @default(autoincrement())
  date       DateTime @unique
  reason     String?
  created_at DateTime @default(now())

  @@index([date])
  @@map("blackout_dates")
}

model Notification {
  id             Int      @id @default(autoincrement())
  user_id        Int
  title          String
  message        String
  type           String
  is_read        Boolean  @default(false)
  reference_id   Int?
  reference_type String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([is_read])
  @@map("notifications")
}

model RetentionPolicy {
  id         Int      @id @default(autoincrement())
  isEnabled  Boolean  @default(false)
  keepDays   Int      @default(30)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("retention_policies")
}

model AccessControlRule {
  id         Int      @id @default(autoincrement())
  section    String   @unique
  roles      Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("access_control_rules")
}

model ChatChannel {
  id            Int                 @id @default(autoincrement())
  name          String?
  type          String
  client_id     Int?
  created_by_id Int
  created_at    DateTime            @default(now())
  updated_at    DateTime            @updatedAt
  is_deleted    Boolean             @default(false)
  members       ChatChannelMember[]
  client        Client?             @relation(fields: [client_id], references: [id], onDelete: Cascade)
  created_by    User                @relation("ChannelCreator", fields: [created_by_id], references: [id])
  messages      ChatMessage[]

  @@index([client_id])
  @@index([created_by_id])
  @@map("chat_channels")
}

model ChatChannelMember {
  id           Int         @id @default(autoincrement())
  channel_id   Int
  user_id      Int
  joined_at    DateTime    @default(now())
  last_read_at DateTime    @default(now())
  channel      ChatChannel @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([channel_id, user_id])
  @@index([channel_id])
  @@index([user_id])
  @@map("chat_channel_members")
}

model ChatMessage {
  id         Int         @id @default(autoincrement())
  channel_id Int
  sender_id  Int
  content    String
  type       String      @default("TEXT")
  metadata   Json?
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt
  channel    ChatChannel @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  sender     User        @relation(fields: [sender_id], references: [id])

  @@index([channel_id])
  @@index([sender_id])
  @@map("chat_messages")
}

model AddOn {
  id             Int      @id @default(autoincrement())
  client_id      Int
  title          String
  description    String?
  date           DateTime
  price          Decimal  @db.Decimal(10, 2)
  assigned_to_id Int?
  created_by_id  Int
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  is_deleted     Boolean  @default(false)
  assigned_to    User?    @relation("AddOnAssignee", fields: [assigned_to_id], references: [id])
  client         Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  created_by     User     @relation("AddOnCreator", fields: [created_by_id], references: [id])

  @@index([client_id])
  @@index([assigned_to_id])
  @@index([created_by_id])
  @@map("addons")
}

model Subscription {
  id             Int      @id @default(autoincrement())
  client_id      Int?
  title          String
  description    String?
  price          Decimal  @db.Decimal(10, 2)
  payment_method String
  due_date       DateTime
  created_by_id  Int
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  is_deleted     Boolean  @default(false)
  client         Client?  @relation(fields: [client_id], references: [id], onDelete: Cascade)
  created_by     User     @relation("SubscriptionCreator", fields: [created_by_id], references: [id])

  @@index([client_id])
  @@index([created_by_id])
  @@map("subscriptions")
}

model TaskToTaskTypes {
  A          Int
  B          Int
  tasks      Task     @relation(fields: [A], references: [id], onDelete: Cascade)
  task_types TaskType @relation(fields: [B], references: [id], onDelete: Cascade)

  @@unique([A, B], map: "_TaskToTaskTypes_AB_unique")
  @@index([B], map: "_TaskToTaskTypes_B_index")
  @@map("_TaskToTaskTypes")
}

model UserToUserRole {
  A          Int
  B          Int
  users      User     @relation(fields: [A], references: [id], onDelete: Cascade)
  user_roles UserRole @relation(fields: [B], references: [id], onDelete: Cascade)

  @@unique([A, B], map: "_UserToUserRole_AB_unique")
  @@index([B], map: "_UserToUserRole_B_index")
  @@map("_UserToUserRole")
}
