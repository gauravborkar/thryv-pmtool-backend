generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
 
// ==================== LOOKUP TABLES ====================

model UserRole {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())

  users User[]

  @@map("user_roles")
}
 
model TaskStatus {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())

  tasks Task[]

  @@map("task_statuses")
}

model PostType {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())

  packages         Package[]
  calendar_entries CalendarEntry[]

  @@map("post_types")
}

model Platform {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())

  packages         Package[]
  calendar_entries CalendarEntry[]

  @@map("platforms")
}

// ==================== MAIN TABLES ====================

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  password   String
  name       String
  role_id    Int
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  // Relations
  role           UserRole @relation(fields: [role_id], references: [id])
  managed_clients Client[] @relation("ClientManager")
  assigned_tasks  Task[]   @relation("TaskDesigner")
  created_tasks   Task[]   @relation("TaskCreator")

  // Indexes
  @@index([role_id])
  @@index([email])
  @@index([is_active])
  @@map("users")
}

model Client {
  id             Int       @id @default(autoincrement())
  name           String
  brand_details  Json?
  platforms      String[]
  active_month   DateTime
  manager_id     Int
  is_active      Boolean   @default(true)
  timezone       String    @default("UTC")
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  // Relations
  manager          User            @relation("ClientManager", fields: [manager_id], references: [id])
  packages         Package[]
  calendar_entries CalendarEntry[]

  // Indexes
  @@index([manager_id])
  @@index([active_month])
  @@index([is_active])
  @@map("clients")
}

model Package {
  id           Int      @id @default(autoincrement())
  client_id    Int
  post_type_id Int
  platform_id  Int
  quantity     Int      @default(1)
  month        DateTime
  created_at   DateTime @default(now())

  // Relations
  client    Client    @relation(fields: [client_id], references: [id])
  post_type PostType  @relation(fields: [post_type_id], references: [id])
  platform  Platform  @relation(fields: [platform_id], references: [id])

  // Indexes & Constraints
  @@unique([client_id, post_type_id, platform_id, month])
  @@index([client_id])
  @@index([month])
  @@map("packages")
}

model CalendarEntry {
  id             Int      @id @default(autoincrement())
  client_id      Int
  date           DateTime
  post_type_id   Int
  platform_id    Int
  creative_brief String?
  created_at     DateTime @default(now())

  // Relations
  client    Client    @relation(fields: [client_id], references: [id])
  post_type PostType  @relation(fields: [post_type_id], references: [id])
  platform  Platform  @relation(fields: [platform_id], references: [id])
  task      Task?

  // Indexes
  @@index([client_id])
  @@index([date])
  @@index([post_type_id])
  @@index([platform_id])
  @@map("calendar_entries")
}

model Task {
  id                    Int        @id @default(autoincrement())
  calendar_entry_id     Int        @unique
  title                 String
  status_id             Int
  priority              Int        @default(2)
  designer_due_date     DateTime
  publish_date          DateTime
  assigned_designer_id  Int?
  created_by_manager_id Int
  media_urls            String[]
  comments              Json[]
  created_at            DateTime   @default(now())
  updated_at            DateTime   @updatedAt

  // Relations
  calendar_entry    CalendarEntry @relation(fields: [calendar_entry_id], references: [id])
  status            TaskStatus    @relation(fields: [status_id], references: [id])
  assigned_designer User?         @relation("TaskDesigner", fields: [assigned_designer_id], references: [id])
  created_by_manager User          @relation("TaskCreator", fields: [created_by_manager_id], references: [id])

  // Indexes
  @@index([assigned_designer_id])
  @@index([status_id])
  @@index([publish_date])
  @@index([designer_due_date])
  @@index([priority])
  @@map("tasks")
}