# =============================================================
# Thryv PM Tool — Backend Environment Variables
# =============================================================
# Copy this file to .env and fill in your local values.
# NEVER commit .env to version control.
# =============================================================

# ----- Database -----
# Local PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL="postgresql://postgres:password@localhost:5432/agency_pm"

# ----- Auth -----
# Secret key used to sign JWT tokens.
# Use any long random string locally (min 32 chars recommended).
JWT_SECRET="your-local-jwt-secret-change-me"

# ----- Server -----
# Port the Express server listens on.
PORT=3001
